# Supply-chain hardening.
# `npm ci` installs lockfile-pinned versions regardless of age, so this cooldown does
# not gate CI installs; it delays adopting freshly-published versions when a version is
# resolved (local `npm install`, and Dependabot bumps). Known vulnerabilities are gated
# separately by `npm audit` in CI.
ignore-scripts=true
min-release-age=7

# Releases go through `npm run release:*`, which bumps with `npm version --no-git-tag-version`
# then runs ../../scripts/release.mjs to commit, tag `typescript-fetch-vX.Y.Z`, and push.
# (Bare `npm version` does NOT tag from a monorepo subdirectory, so no tag-version-prefix
# is set here — the release script owns the tag name.)
